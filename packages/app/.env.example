# GitHub OAuth App — create at github.com/settings/apps
# Callback URL: https://your-domain.com/auth/github/callback
# Required scopes: repo, user:email
GITHUB_OAUTH_CLIENT_ID=Ov23li...
GITHUB_OAUTH_CLIENT_SECRET=abc123...

# Session signing key — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-at-least-32-random-characters

# Token encryption key — generate with: openssl rand -hex 16
# Used to encrypt stored GitHub OAuth tokens at rest.
TOKEN_SECRET=change-me-exactly-32-characters!!

# Public URL of this WritingDesk instance (no trailing slash)
ORIGIN=https://writingdesk.yourdomain.com

# Root directory for all persistent data.
# Mount a PersistentVolumeClaim (Kubernetes) or named volume (Docker) here.
#
# Layout:
#   DATA_DIR/db.sqlite                        ← SQLite database
#   DATA_DIR/workspaces/{owner}/{repo}/       ← git clone per blog repo
#
# Isolation: the owner/repo subdirectory structure mirrors GitHub's own
# globally-unique namespace, guaranteeing no two blogs ever share a path.
#
# Kubernetes: use ReadWriteOnce for single-replica deployments.
# For HA (multiple replicas), use ReadWriteMany (NFS, EFS, Longhorn, etc.)
# or move the database to a separate PVC / external Postgres instance.
#
# DATA_DIR=/var/writingdesk
